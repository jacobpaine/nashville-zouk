# Copy this file to .env.local and fill in your values.

# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Public base URL for uploaded assets (e.g. https://your-bucket.s3.amazonaws.com)
AWS_S3_PUBLIC_URL=

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender address
EMAIL_FROM=Nashville Zouk <hello@nashvillezouk.com>

# ─── Auth (iron-session) ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (REQUIRED — do not leave blank)
SESSION_SECRET=

# ─── Admin credentials (dev only — use DB in production) ─────────────────────
ADMIN_EMAIL=admin@nashvillezouk.com
ADMIN_PASSWORD=change-me

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Analytics (Umami) ───────────────────────────────────────────────────────
# From your Umami dashboard → Settings → Websites
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Umami script src (e.g. https://analytics.umami.is/script.js or your self-hosted URL)
NEXT_PUBLIC_UMAMI_SRC=
